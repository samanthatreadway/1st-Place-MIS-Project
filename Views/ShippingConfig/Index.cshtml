@model IEnumerable<fa25group23final.Models.Shippingconfig>

@{
    ViewData["Title"] = "Shipping Settings";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">
            <i class="fas fa-truck me-2"></i> Shipping Settings
        </h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus-circle me-1"></i> Create New
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>First Book Fee</th>
                        <th>Additional Book Fee</th>
                        <th>Active?</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FirstBookFee.ToString("C")</td>
                            <td>@item.AdditionalBookFee.ToString("C")</td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>

                            <td class="text-end">

                                <!-- Only show Set Active for inactive configs -->
                                @if (!item.IsActive)
                                {
                                    <a asp-action="SetActive"
                                       asp-route-id="@item.ShippingConfigID"
                                       class="btn btn-sm btn-outline-success me-1">
                                        <i class="fas fa-check"></i> Set Active
                                    </a>
                                }
                                else
                                {
                                    <!-- Optional: disable delete on active config -->
                                    <button class="btn btn-sm btn-outline-secondary" disabled>
                                        Active
                                    </button>
                                }

                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>
</div>



@model fa25group23final.Models.Coupon

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Coupon</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CouponID" value="@Model.CouponID" />
            <input type="hidden" asp-for="CouponCode" value="@Model.CouponCode" />
            <input type="hidden" asp-for="CouponType" value="@Model.CouponType" />
            <input type="hidden" asp-for="DiscountPercent" value="@Model.DiscountPercent" />
            <input type="hidden" asp-for="FreeThreshold" value="@Model.FreeThreshold" />

            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Status" />
                    @Html.DisplayNameFor(model => model.Status)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>


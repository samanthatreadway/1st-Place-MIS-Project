<div class="container mt-5 d-flex justify-content-center">
    <div class="card shadow p-4" style="max-width: 500px; width: 100%; border-radius: 12px;">

        <h2 class="text-center mb-3">Edit Coupon</h2>
        <hr />

        <form asp-action="Edit" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Hidden fields for existing values -->
            <input type="hidden" asp-for="CouponID" />
            <input type="hidden" asp-for="CouponCode" />
            <input type="hidden" asp-for="CouponType" />
            <input type="hidden" asp-for="DiscountPercent" />
            <input type="hidden" asp-for="FreeThreshold" />

            <!-- Status -->
            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Status" />
                <label class="form-check-label fw-semibold" asp-for="Status"></label>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-primary w-100">
                Save
            </button>

        </form>

        <div class="mt-3 text-center">
            <a asp-action="Index" class="btn btn-outline-secondary">
                Back to List
            </a>
        </div>

    </div>
</div>

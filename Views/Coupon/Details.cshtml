<div class="container mt-5 d-flex justify-content-center">
    <div class="card shadow p-4" style="max-width: 600px; width: 100%; border-radius: 12px;">

        <h2 class="text-center mb-3">Coupon Details</h2>
        <hr />

        <dl class="row mb-4">
            <dt class="col-sm-4 text-muted">Coupon Code</dt>
            <dd class="col-sm-8">@Model.CouponCode</dd>

            <dt class="col-sm-4 text-muted">Coupon Type</dt>
            <dd class="col-sm-8">@Model.CouponType</dd>

            <dt class="col-sm-4 text-muted">Discount %</dt>
            <dd class="col-sm-8">@Model.DiscountPercent</dd>

            <dt class="col-sm-4 text-muted">Free Threshold</dt>
            <dd class="col-sm-8">@Model.FreeThreshold</dd>

            <dt class="col-sm-4 text-muted">Active</dt>
            <dd class="col-sm-8">@Model.Status</dd>
        </dl>

        <div class="d-flex justify-content-between">
            <a asp-action="Edit" asp-route-id="@Model.CouponID" class="btn btn-primary px-4">
                Edit
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                Back to List
            </a>
        </div>

    </div>
</div>
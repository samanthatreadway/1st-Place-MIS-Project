<div class="container mt-5">

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Create New Coupon</h4>
        </div>

        <div class="card-body">

            <form asp-action="CreateFinal">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Coupon Code -->
                <div class="mb-3">
                    <label asp-for="CouponCode" class="form-label fw-semibold"></label>
                    <input asp-for="CouponCode" class="form-control" placeholder="Enter coupon code" />
                    <span asp-validation-for="CouponCode" class="text-danger small"></span>
                </div>

                <!-- Coupon Type (Radio Buttons) -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Coupon Type</label>

                    <div class="form-check">
                        <input type="radio" asp-for="CouponType" value="@CouponTypeEnum.Discount"
                               class="form-check-input" checked />
                        <label class="form-check-label">Discount</label>
                    </div>

                    <div class="form-check">
                        <input type="radio" asp-for="CouponType" value="@CouponTypeEnum.FreeShipping"
                               class="form-check-input" />
                        <label class="form-check-label">Free Shipping</label>
                    </div>

                    <span asp-validation-for="CouponType" class="text-danger small"></span>
                </div>

                <!-- Submit -->
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        Next Page
                    </button>
                </div>

            </form>

        </div>
    </div>

    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            Back to List
        </a>
    </div>

</div>

<div class="container mt-5">

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Create Free Shipping Coupon</h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- keep values from previous step -->
                <input type="hidden" name="CouponCode" value="@Model.CouponCode" />
                <input type="hidden" name="CouponType" value="@Model.CouponType" />

                <!-- Free Shipping Threshold -->
                <div class="mb-3">
                    <label asp-for="FreeThreshold" class="form-label fw-semibold"></label>
                    <input asp-for="FreeThreshold" class="form-control" placeholder="Enter free shipping minimum $" />
                    <span asp-validation-for="FreeThreshold" class="text-danger small"></span>
                </div>

                @*<div class="form-group">
                    <label asp-for="DiscountPercent" class="control-label"></label>
                    <input asp-for="DiscountPercent" class="form-control" />
                    <span asp-validation-for="DiscountPercent" class="text-danger"></span>
                </div>*@

                <!-- Active Status Checkbox -->
                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Status" />
                    <label class="form-check-label fw-semibold" asp-for="Status"></label>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn btn-primary px-4">
                    Create
                </button>

            </form>

        </div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Back to List
    </a>

</div>

@model fa25group23final.Models.ViewModels.Orders.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<div class="container my-4">
    <h2 class="mb-4"><i class="fas fa-shopping-cart"></i> Checkout</h2>

    @* Display messages *@
    @if (ViewBag.SuccessMessage != null || TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @(ViewBag.SuccessMessage ?? TempData["SuccessMessage"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (ViewBag.ErrorMessage != null || TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @(ViewBag.ErrorMessage ?? TempData["ErrorMessage"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (ViewBag.InfoMessage != null || TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="fas fa-info-circle"></i> @(ViewBag.InfoMessage ?? TempData["InfoMessage"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        @* Left Column - Shipping, Payment, and Coupon *@
        <div class="col-lg-8">
            
            @* Shipping Address Card *@
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-shipping-fast"></i> Shipping Address</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ShippingAddress))
                    {
                        @* Display address based on whether it's separated or combined *@
                        @if (Model.IsAddressSeparated)
                        {
                            @* Separated address fields (future) *@
                            <address class="mb-0">
                                <strong>Ship to:</strong><br />
                                @Model.Street<br />
                                @Model.City, @Model.State @Model.ZipCode
                            </address>
                        }
                        else
                        {
                            @* Combined address field (current) *@
                            <address class="mb-0">
                                <strong>Ship to:</strong><br />
                                @Model.ShippingAddress
                            </address>
                        }
                        
                        <hr class="my-2" />
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i> 
                            Need to update your address? 
                            <a asp-controller="Account" asp-action="Edit" target="_blank">
                                Go to Profile
                            </a>
                        </small>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="fas fa-exclamation-triangle"></i> 
                            No shipping address on file. 
                            <a asp-controller="Account" asp-action="Index">
                                Please add your address
                            </a> before checking out.
                        </div>
                    }
                </div>
            </div>

            @* Payment Information Card *@
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-credit-card"></i> Payment Information</h5>
                </div>
                <div class="card-body">
                    @if (Model.CreditCardOptions.Any())
                    {
                        <form asp-action="PlaceOrder" method="post" id="checkoutForm">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Select Credit Card:</label>
                                @foreach (var card in Model.CreditCardOptions)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" 
                                               type="radio" 
                                               name="selectedCreditCardId" 
                                               id="card_@card.Value" 
                                               value="@card.Value"
                                               required>
                                        <label class="form-check-label" for="card_@card.Value">
                                            <i class="fas fa-credit-card text-primary"></i> @card.Text
                                        </label>
                                    </div>
                                }
                            </div>

                            <div class="mt-3">
                                @if (Model.CreditCardOptions.Count >= 3)
                                {
                                    <div class="alert alert-info py-2 px-3">
                                        <small>
                                            <i class="fas fa-info-circle"></i> 
                                            Maximum of 3 credit cards reached. Delete a card to add a new one.
                                        </small>
                                    </div>
                                }
                                else
                                {
                                    <a asp-controller="CreditCard" 
                                       asp-action="Create" 
                                       asp-route-returnUrl="@Url.Action("Checkout", "Orders")"
                                       class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-plus"></i> Add New Credit Card
                                    </a>
                                }
                            </div>

                            

                            @* Disable Place Order if no address *@
                            @* @if (!string.IsNullOrEmpty(Model.ShippingAddress))
                            {
                                <button type="submit" 
                                        class="btn btn-success btn-lg w-100" 
                                        onclick="return confirm('Are you sure you want to place this order?')">
                                    <i class="fas fa-check"></i> Place Order
                                </button>
                            }
                            else
                            {
                                <button type="button" 
                                        class="btn btn-secondary btn-lg w-100" 
                                        disabled
                                        title="Please add a shipping address first">
                                    <i class="fas fa-ban"></i> Add Shipping Address to Continue
                                </button>
                            } *@
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> 
                            You don't have any credit cards on file.
                        </div>
                        <a asp-controller="CreditCard" 
                           asp-action="Create" 
                           asp-route-returnUrl="@Url.Action("Checkout", "Orders")"
                           class="btn btn-primary">
                            <i class="fas fa-plus"></i> Add Credit Card
                        </a>
                    }
                </div>
            </div>

            @* Order Items Card *@
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-book"></i> Order Items (@Model.ItemCount book@(Model.ItemCount != 1 ? "s" : ""))</h5>
                </div>
                <div class="card-body">
                    @if (Model.Items.Any())
                    {
                        <div class="list-group">
                            @foreach (var item in Model.Items)
                            {
                                <div class="list-group-item">
                                    <div class="row align-items-center">
                                        <div class="col-md-1">
                                            <i class="fas fa-book fa-2x text-primary"></i>
                                        </div>
                                        <div class="col-md-6">
                                            <h6 class="mb-1">@item.bookID.Title</h6>
                                            <small class="text-muted">by @item.bookID.Authors</small>
                                        </div>
                                        <div class="col-md-2 text-center">
                                            <span class="badge bg-secondary">Qty: @item.Quantity</span>
                                        </div>
                                        <div class="col-md-3 text-end">
                                            <div>@item.Price.ToString("C") each</div>
                                            <div class="fw-bold">@((item.Price * item.Quantity).ToString("C"))</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No items in cart</p>
                    }
                </div>
            </div>
        </div>

        @* Right Column - Order Summary *@
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 20px;">

                @* Coupon Code Card *@
                <div class="card mb-3">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-tag"></i> Coupon Code</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.AppliedCoupon != null)
                        {
                            <div class="alert alert-success">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="fas fa-check-circle"></i>
                                        <strong>
                                            @if (Model.AppliedCoupon.CouponType == CouponTypeEnum.Discount)
                                            {
                                                <text>Coupon '@Model.AppliedCoupon.CouponCode' applied: @Model.AppliedCoupon.DiscountPercent% off</text>
                                            }
                                            else
                                            {
                                                <text>Coupon '@Model.AppliedCoupon.CouponCode' applied: Free shipping</text>
                                            }
                                        </strong>
                                        <br />
                                        <small>Code: @Model.AppliedCoupon.CouponCode</small>
                                    </div>
                                    <form asp-action="RemoveCoupon" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-times"></i> Remove
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                        else
                        {
                            <form asp-action="ApplyCoupon" method="post">
                                <div class="row g-2">
                                    <div class="col-md-8">
                                        <input type="text"
                                               name="couponCode"
                                               class="form-control"
                                               placeholder="Enter coupon code"
                                               pattern="[A-Za-z0-9]{1,20}"
                                               title="Coupon code must be 1-20 alphanumeric characters">
                                    </div>
                                    <div class="col-md-4">
                                        <button type="submit" class="btn btn-primary w-100">
                                            <i class="fas fa-tag"></i> Apply
                                        </button>
                                    </div>
                                </div>
                                <small class="text-muted">
                                    Have a discount code? Enter it here to save on your order!
                                </small>
                            </form>
                        }
                    </div>
                </div>

                @* Order Summary Card *@
                <div class="card mb-3">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="fas fa-receipt"></i> Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal (@Model.ItemCount item@(Model.ItemCount != 1 ? "s" : "")):</span>
                            <span>@Model.Subtotal.ToString("C")</span>
                        </div>
                        
                        <div class="d-flex justify-content-between mb-2">
                            <span>
                                Shipping:
                                @if (Model.ShippingConfig != null)
                                {
                                    <br />
                                    <small class="text-muted">
                                        (@Model.ShippingConfig.FirstBookFee.ToString("C") first + 
                                        @Model.ShippingConfig.AdditionalBookFee.ToString("C") each additional)
                                    </small>
                                }
                            </span>
                            <span>@Model.ShippingFee.ToString("C")</span>
                        </div>

                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span>
                                    <i class="fas fa-tag"></i> Discount:
                                    @if (Model.AppliedCoupon != null)
                                    {
                                        <br />
                                        <small>(@Model.AppliedCoupon.CouponCode)</small>
                                    }
                                </span>
                                <span>-@Model.DiscountAmount.ToString("C")</span>
                            </div>
                        }

                        <hr />

                        <div class="d-flex justify-content-between">
                            <h5>Total:</h5>
                            <h5 class="text-primary">@Model.Total.ToString("C")</h5>
                        </div>

                        <br />

                        @* Place Order Button block before the security notice *@
                        @if (Model.CreditCardOptions.Any())
                        {
                            if (!string.IsNullOrEmpty(Model.ShippingAddress))
                            {
                                <button form="checkoutForm" type="submit" class="btn btn-success btn-lg w-100 mb-2" onclick="return confirm('Are you sure you want to place this order?')">
                                    <i class="fas fa-check"></i> Place Order
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-secondary btn-lg w-100 mb-2" disabled title="Please add a shipping address first">
                                    <i class="fas fa-ban"></i> Add Shipping Address to Continue
                                </button>
                            }
                        }
                        else
                        {
                            <a asp-controller="CreditCard"
                               asp-action="Create"
                               asp-route-returnUrl="@Url.Action("Checkout", "Orders")"
                               class="btn btn-primary w-100 mb-2">
                                <i class="fas fa-plus"></i> Add Credit Card
                            </a>
                        }

                        <div class="text-center">
                            <small class="text-muted">Placing an order will finalize the transaction and charge your selected card.</small>
                        </div>
                    </div>
                </div>

                @* Security Notice *@
                <div class="card">
                    <div class="card-body text-center">
                        <i class="fas fa-lock fa-2x text-success mb-2"></i>
                        <p class="mb-0"><small>Secure Checkout</small></p>
                        <p class="text-muted mb-0"><small>Your payment information is protected</small></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Back to Cart Link *@
    <div class="mt-4 text-center">
        <a asp-action="ShoppingCart" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Back to Shopping Cart
        </a>
    </div>
</div>

@section Scripts {
    <script>

        setTimeout(function () {
            $('.alert:not(.alert-success)').alert('close');
        }, 5000);

        // Auto-dismiss alerts after 5 seconds
        // setTimeout(function() {
        //     $('.alert').fadeOut('slow');
        // }, 5000);
    </script>
}

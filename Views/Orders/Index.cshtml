<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        @if (User.IsInRole("Customer"))
        {
        <h2 class="fw-bold">
            <i class="fas fa-shopping-bag me-2"></i> My Order History
        </h2>
            <a asp-action="ShoppingCart" class="btn btn-primary shadow-sm">
                <i class="fas fa-shopping-cart me-1"></i> View Cart
            </a>
        }
        else
        {
        <h2 class="fw-bold">
            <i class="fas fa-shopping-bag me-2"></i> Customer Order History
        </h2>
        }
    </div>

    <!-- No Orders Message -->
    @if (!Model.Any())
    {
        @if (User.IsInRole("Customer"))
        {
            <div class="alert alert-info shadow-sm">
                <i class="fas fa-info-circle"></i> You haven't placed any orders yet.
                <br />
                <a asp-controller="Books" asp-action="Index" class="alert-link fw-bold">
                    Start shopping now!
                </a>
            </div>
        }
        else
        {
            <div class="alert alert-info shadow-sm">
                <i class="fas fa-info-circle"></i> No customer orders to show.
            </div>
        }

    }
    else
    {
        <!-- Orders Table -->
        <div class="card shadow-sm">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Order #</th>
                                <th>Date</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Credit Card</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var order in Model)
                            {
                                decimal subtotal = order.OrderDetails.Sum(od => od.Price * od.Quantity);
                                decimal shipping = order.ShippingFee ?? 0m;
                                decimal discount = 0m;

                                if (order.couponID != null)
                                {
                                    if (order.couponID.CouponType == CouponTypeEnum.Discount &&
                                        order.couponID.DiscountPercent.HasValue)
                                    {
                                        discount = subtotal * (order.couponID.DiscountPercent.Value / 100m);
                                    }
                                    else if (order.couponID.CouponType == CouponTypeEnum.FreeShipping)
                                    {
                                        if (!order.couponID.FreeThreshold.HasValue ||
                                            subtotal >= order.couponID.FreeThreshold.Value)
                                        {
                                            discount = shipping;
                                        }
                                    }
                                }

                                decimal total = subtotal + shipping - discount;
                                int itemCount = order.OrderDetails.Sum(od => od.Quantity);

                                <tr>
                                    <td><strong>#@order.OrderID</strong></td>

                                    <td>
                                        @if (order.OrderDate.HasValue)
                                        {
                                            @order.OrderDate.Value.ToString("MMM dd, yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">Pending</span>
                                        }
                                    </td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @itemCount item@(itemCount != 1 ? "s" : "")
                                        </span>
                                    </td>

                                    <td>
                                        <strong>@total.ToString("C")</strong>
                                        @if (discount > 0)
                                        {
                                            <br />
                                            <small class="text-success">
                                                <i class="fas fa-tag"></i> -@discount.ToString("C")
                                            </small>
                                        }
                                    </td>

                                    <td>
                                        @{
                                            string maskedCard = "N/A";

                                            if (order.creditCard != null &&
                                                !string.IsNullOrEmpty(order.creditCard.CardNumber) &&
                                                order.creditCard.CardNumber.Length >= 4)
                                            {
                                                // Get last 4 digits
                                                var last4 = order.creditCard.CardNumber
                                                    .Substring(order.creditCard.CardNumber.Length - 4);

                                                // Enum → string
                                                string cardTypeText = order.creditCard.CardType.ToString();

                                                // Ex: "Visa **** **** **** 1234"
                                                maskedCard = $"{cardTypeText} ************{last4}";
                                            }
                                        }

                                        <span class="text-muted">@maskedCard</span>
                                    </td>


                                    <td>
                                        @if (order.OrderStatus)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check"></i> Completed
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-shopping-cart"></i> In Cart
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <a asp-action="Details"
                                           asp-route-id="@order.OrderID"
                                           class="btn btn-sm btn-primary shadow-sm">
                                            <i class="fas fa-eye"></i> View Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

        <!-- Footer -->
        <div class="mt-3 text-muted">
            <i class="fas fa-info-circle me-1"></i>
            Showing @Model.Count() order@(Model.Count() != 1 ? "s" : "")
        </div>
    }
</div>



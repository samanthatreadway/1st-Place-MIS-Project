<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Edit Customer</h3>
                </div>
                <div class="card-body">
                    <form asp-action="CustomerEdit">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input type="hidden" class="form-check-input" asp-for="Status" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <input type="submit" value="Save" class="btn btn-primary btn-block" />
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center">
                    <a asp-action="ConfirmFire" asp-route-id="@Model.Id" class="btn btn-warning">Disable Customer</a>

                    <a asp-action="Rehire" asp-route-id="@Model.Id" class="btn btn-secondary">Enable Customer</a>
                    <a asp-action="ManageCustomers" class="btn btn-secondary">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>
@model fa25group23final.Models.AppUser





<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-sm text-center p-4" style="max-width: 400px; width: 100%;">
        <h2 class="mb-4">Are you sure?</h2>
        <p class="mb-4">Do you really want to proceed with this action?</p>

        <div class="d-flex justify-content-center gap-3">
            <form asp-action="FireEmployee" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success px-4">Confirm</button>
            </form>

            <a asp-action="ManageEmployees" class="btn btn-danger px-4">Cancel</a>
        </div>
    </div>
</div>
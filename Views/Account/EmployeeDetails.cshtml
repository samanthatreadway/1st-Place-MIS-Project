<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Employee Details</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">First Name</div>
                        <div class="col-sm-8">@Html.DisplayFor(model => model.FirstName)</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">Last Name</div>
                        <div class="col-sm-8">@Html.DisplayFor(model => model.LastName)</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">Address</div>
                        <div class="col-sm-8">@Html.DisplayFor(model => model.Address)</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">Status</div>
                        <div class="col-sm-8">@Html.DisplayFor(model => model.Status)</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">ID</div>
                        <div class="col-sm-8">@Html.DisplayFor(model => model.Id)</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">Username</div>
                        <div class="col-sm-8">@Html.DisplayFor(model => model.UserName)</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">Email</div>
                        <div class="col-sm-8">@Html.DisplayFor(model => model.Email)</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 fw-bold">Phone Number</div>
                        <div class="col-sm-8">@Html.DisplayFor(model => model.PhoneNumber)</div>
                    </div>
                </div>
                <div class="card-footer text-center">
                    <a asp-action="ManageEmployees" class="btn btn-secondary">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>
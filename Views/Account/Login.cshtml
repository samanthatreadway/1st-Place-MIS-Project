<!-- Dark Login Page -->
<div class="login-page d-flex align-items-center justify-content-center vh-100 bg-dark">
    <div class="login-card card p-4 shadow-lg rounded-lg text-white" style="max-width: 400px; width: 100%;">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Login</h2>
            <hr class="border-light" />
        </div>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="d-grid mb-3">
                <input type="submit" value="Login" class="btn btn-primary btn-lg" />
            </div>
        </form>

        <div class="text-center">
            <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none me-3">Home</a>
            <a asp-controller="Account" asp-action="Register" class="text-white text-decoration-none">Register</a>
        </div>
    </div>
</div>

<style>
.login-page {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100vh;
    overflow: hidden;
}

.login-page::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('@Url.Content("~/images/inside.jpg")');    background-size: cover;
    background-position: center;
    filter: blur(8px) brightness(0.6);
    z-index: 0;
}

.login-card {
    position: relative;
    z-index: 1; /* Keep card above blurred background */
    background-color: rgba(33, 37, 41, 0.85); /* Slight transparency for blending */
    border: none;
    padding: 2rem;
    max-width: 400px;
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 12px 25px rgba(0,0,0,0.3);
}

.login-card input.form-control {
    border-radius: 8px;
}

.login-card .btn-primary {
    border-radius: 8px;
    transition: all 0.2s ease-in-out;
}

.login-card .btn-primary:hover {
    background-color: #0d6efdcc;
    transform: translateY(-2px);
}

.login-card a {
    color: #ffffff;
}

.login-card a:hover {
    text-decoration: underline;
    color: #0d6efd;
}
</style>
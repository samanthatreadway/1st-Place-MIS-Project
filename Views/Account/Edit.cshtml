<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm rounded-lg">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Edit Account</h3>
                </div>
                <div class="card-body">
                    <form asp-action="EditPost" asp-controller="Account">
                        <input type="hidden" asp-for="ID" />

                        @if (User.IsInRole("Employee") || User.IsInRole("Admin"))
                        {
                            <input type="hidden" asp-for="FirstName" />
                            <input type="hidden" asp-for="LastName" />
                        }

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Phone Number -->
                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        @if (User.IsInRole("Customer"))
                        {
                            <!-- First Name -->
                            <div class="mb-3">
                                <label asp-for="FirstName" class="form-label"></label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <!-- Last Name -->
                            <div class="mb-3">
                                <label asp-for="LastName" class="form-label"></label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        }

                        <!-- Address -->
                        <div class="mb-4">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid">
                            <input type="submit" value="Save Changes" class="btn btn-success btn-lg" />
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center">
                    <a asp-controller="Home" asp-action="UserDashboard" class="text-decoration-none">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-header {
        border-bottom: none;
    }

    .card-body input.form-control {
        border-radius: 8px;
    }

    .btn-success:hover {
        background-color: #28a745cc;
        transform: translateY(-2px);
        transition: all 0.2s ease-in-out;
    }
</style>
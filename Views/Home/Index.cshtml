@* CUSTOMER-ONLY, DATABASE-DRIVEN COUPON SECTION *@
@if (User.Identity.IsAuthenticated && User.IsInRole("Customer") && Model != null && Model.Any())
{
    <div class="promo-section py-4 bg-warning text-dark">
        <div class="container text-center">
            <h2 class="h4 mb-2">Coupon Codes</h2>

            @foreach (var coupon in Model)
            {
                <p class="mb-1">
                    @if (coupon.CouponType == fa25group23final.Models.CouponTypeEnum.Discount)
                    {
                        @($"Use code {coupon.CouponCode} to get {coupon.DiscountPercent}% off your order!")
                    }
                    else if (coupon.CouponType == fa25group23final.Models.CouponTypeEnum.FreeShipping)
                    {
                        @($"Use code {coupon.CouponCode} for free shipping on orders over ${coupon.FreeThreshold}!")
                    }
                </p>
            }

            <p class="mb-0">
                Apply your coupon at checkout to save!
            </p>
        </div>
    </div>

    <style>
        .promo-section {
            font-size: 1.05rem;
            letter-spacing: 0.02em;
        }
    </style>
}


<!-- Call-to-Action Section -->
<div class="cta-section text-center py-5 bg-light">
    <a asp-action="Index" asp-controller="Books" class="btn btn-dark btn-lg shadow-lg cta-btn">
        View Our Books
    </a>
</div>

<style>
    .cta-section {
        /* Optional: subtle background gradient for elegance */
        background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .cta-btn {
        padding: 1.25rem 2.5rem;
        font-size: 1.75rem;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .cta-btn:hover {
            background-color: #212529; /* darker shade on hover */
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
        }
</style>






<!-- Mission / About Us Section -->
<div class="mission-section py-5 bg-white">
    <div class="container">
        <h2 class="text-center mb-5">Who We Are</h2>
        <div class="row justify-content-center">
            <!-- Story / Mission -->
            <div class="col-md-8 text-center">
                <h4>Our Story</h4>
                <p>
                    Bevo's Books was founded with the goal of creating a community for book lovers of all kinds.
                    We believe in the power of stories to educate, inspire, and connect people across generations.
                    Our mission is to provide a curated selection of books and a seamless online experience for every reader.
                </p>

                <h4 class="mt-4">Our Mission</h4>
                <p>
                    To deliver a welcoming and engaging bookstore experience online, connecting readers with
                    the stories they love and providing tools to review, share, and manage their collections efficiently.
                </p>
                <a asp-controller="Home" asp-action="MeetTheTeam" class="btn btn-primary btn-lg">
                    Meet the Team
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .mission-section h2,
    .mission-section h4,
    .mission-section p {
        text-align: center;
    }

    .mission-section h2 {
        font-weight: 700;
    }

    .mission-section h4 {
        font-weight: 600;
        margin-top: 1rem;
        color: #212529;
    }

    .mission-section p {
        font-size: 1rem;
        line-height: 1.6;
        color: #495057;
    }

    .mission-section a:hover {
        text-decoration: underline;
        color: #0d6efd;
    }
</style>





<!-- Featured Books Section -->
<div class="featured-books-section py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-5">Featured Books</h2>
        <div class="row g-4 justify-content-center">

            <!-- Top 3 Most Popular Books -->
            <!-- Book 1 - The Other Queen by Philippa Gregory -->
            <div class="col-6 col-md-3">
                <div class="book-card position-relative">
                    <img src="~/images/Queen.jpg"
                         asp-append-version="true"
                         class="img-fluid rounded shadow-sm"
                         alt="The Other Queen by Philippa Gregory">

                    <div class="book-overlay d-flex align-items-center justify-content-center text-center px-2">
                        <span class="text-white fw-bold">
                            The Other Queen<br />
                            <small>by Philippa Gregory</small>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Book 2 - Reckless by Selena Montgomery -->
            <div class="col-6 col-md-3">
                <div class="book-card position-relative">
                    <img src="~/images/Reckless.jpg"
                         asp-append-version="true"
                         class="img-fluid rounded shadow-sm"
                         alt="Reckless by Selena Montgomery">

                    <div class="book-overlay d-flex align-items-center justify-content-center text-center px-2">
                        <span class="text-white fw-bold">
                            Reckless<br />
                            <small>by Selena Montgomery</small>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Book 3 - Wrecked by Anna Davies -->
            <div class="col-6 col-md-3">
                <div class="book-card position-relative">
                    <img src="~/images/Wreck.jpg"
                         asp-append-version="true"
                         class="img-fluid rounded shadow-sm"
                         alt="Wrecked by Anna Davies">

                    <div class="book-overlay d-flex align-items-center justify-content-center text-center px-2">
                        <span class="text-white fw-bold">
                            Wrecked<br />
                            <small>by Anna Davies</small>
                        </span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .featured-books-section h2 {
        font-weight: 700;
    }

    .book-card {
        overflow: hidden;
        border-radius: 12px;
    }

        .book-card img {
            transition: transform 0.3s ease;
        }

        .book-card:hover img {
            transform: scale(1.05);
        }

    .book-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.35);
        opacity: 0;
        transition: opacity 0.3s ease;
        border-radius: 12px;
        text-align: center;
    }

    .book-card:hover .book-overlay {
        opacity: 1;
    }

    .book-overlay span {
        font-size: 1rem;
    }
</style>


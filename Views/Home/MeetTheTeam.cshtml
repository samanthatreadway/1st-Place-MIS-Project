

@{
    ViewData["Title"] = "Meet the Team";
}

<!-- Page Header -->
<div class="container my-5 text-center">
    <h1 class="display-4 mb-3">Meet the Team</h1>
    <p class="lead text-muted">Get to know the amazing people behind our company.</p>
</div>

<!-- Team Cards -->
<div class="container">
    <div class="row g-4 justify-content-center">
        <!-- Team Member 1 -->
        <div class="col-md-6 col-lg-3">
            <div class="team-card p-4 text-center bg-white rounded shadow-sm">
                <img src="~/images/vicky.jpeg" class="rounded-circle mb-3" alt="Team Member 1" width="120" height="120">
                <h5 class="mb-1">Vicky Hu</h5>
                <p class="text-muted small">The Late Night Coder</p>
            </div>
        </div>

        <!-- Team Member 2 -->
        <div class="col-md-6 col-lg-3">
            <div class="team-card p-4 text-center bg-white rounded shadow-sm">
                <img src="~/images/samantha.jpeg" class="rounded-circle mb-3" alt="Team Member 2" width="120" height="120">
                <h5 class="mb-1">Samantha Treadway</h5>
                <p class="text-muted small">The Intel Specialist</p>
            </div>
        </div>

        <!-- Team Member 3 -->
        <div class="col-md-6 col-lg-3">
            <div class="team-card p-4 text-center bg-white rounded shadow-sm">
                <img src="~/images/stephanie.jpeg" class="rounded-circle mb-3" alt="Team Member 3" width="120" height="120">
                <h5 class="mb-1">Stephanie Xia</h5>
                <p class="text-muted small">The Utility Specialist</p>
            </div>
        </div>

        <!-- Team Member 4 -->
        <div class="col-md-6 col-lg-3">
            <div class="team-card p-4 text-center bg-white rounded shadow-sm">
                <img src="~/images/owen.jpeg" class="rounded-circle mb-3" alt="Team Member 4" width="120" height="120">
                <h5 class="mb-1">Owen Tippett</h5>
                <p class="text-muted small">The Daytime Coder</p>
            </div>
        </div>
    </div>
</div>

<!-- Custom CSS for hover effect -->
<style>
    body {
        background-color: #f8f9fa;
    }

    .team-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

        .team-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
        }

        .team-card img {
            object-fit: cover;
        }
</style>
<h1 class="mb-4 text-center text-danger">Delete Credit Card</h1>

<div class="d-flex justify-content-center">
    <div class="card shadow-sm delete-card p-4">
        <div class="card-body text-center">

            <h3 class="mb-3 text-danger">Are you sure?</h3>
            <p class="text-muted mb-4">This action cannot be undone.</p>

            <hr />

            <div class="text-start mb-4">
                <p><strong>Card Number:</strong> @Html.DisplayFor(model => model.CardNumber)</p>
                <p><strong>Card Type:</strong> @Html.DisplayFor(model => model.CardType)</p>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="CardID" />

                <div class="d-flex justify-content-center gap-3">
                    <button type="submit" class="btn btn-danger px-4">Delete</button>
                    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                </div>
            </form>

        </div>
    </div>
</div>

<style>
    .delete-card {
        max-width: 450px;
        width: 100%;
        border-radius: 15px;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .delete-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 24px rgba(0,0,0,0.12);
        }

        .delete-card .btn {
            border-radius: 8px;
            padding: 0.6rem 1.3rem;
            font-size: 1rem;
            font-weight: 600;
        }
</style>
<h1 class="mb-4 text-center">Edit Credit Card</h1>

<div class="d-flex justify-content-center">
    <div class="card shadow-sm edit-card p-4">
        <div class="card-body">

            <h4 class="text-center mb-4">Credit Card Details</h4>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="CardID" />

                <!-- Card Number -->
                <div class="mb-3">
                    <label asp-for="CardNumber" class="form-label fw-semibold"></label>
                    <input asp-for="CardNumber" class="form-control" />
                    <span asp-validation-for="CardNumber" class="text-danger"></span>
                </div>

                <!-- Card Type -->
                <div class="mb-4">
                    <label asp-for="CardType" class="form-label fw-semibold"></label>
                    <select asp-for="CardType"
                            asp-items="Html.GetEnumSelectList<CreditCardTypeEnum>()"
                            class="form-control"></select>
                    <span asp-validation-for="CardType" class="text-danger"></span>
                </div>

                <!-- Save button -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>

        </div>
    </div>
</div>

<div class="text-center mt-3">
    <a asp-action="Index" class="text-decoration-none">Back to List</a>
</div>

<style>
    .edit-card {
        max-width: 450px;
        width: 100%;
        border-radius: 15px;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .edit-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 24px rgba(0,0,0,0.12);
        }

        .edit-card input,
        .edit-card select {
            border-radius: 8px;
            padding: 10px;
        }

        .edit-card .btn {
            border-radius: 8px;
            padding: 0.6rem;
            font-size: 1.05rem;
            font-weight: 600;
        }
</style>
@model fa25group23final.Models.Reviews

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create</title>
</head>
<body>

<h4>Reviews</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Rating" class="control-label"></label>
                <input asp-for="Rating" class="form-control" />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReviewText" class="control-label"></label>
                <input asp-for="ReviewText" class="form-control" />
                <span asp-validation-for="ReviewText" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DisputeStatus" class="control-label"></label>
                <input asp-for="DisputeStatus" class="form-control" />
                <span asp-validation-for="DisputeStatus" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="reviewerID" class="control-label"></label>
                <select asp-for="reviewerID" class ="form-control" asp-items="ViewBag.reviewerID"></select>
            </div>
            <div class="form-group">
                <label asp-for="approverID" class="control-label"></label>
                <select asp-for="approverID" class ="form-control" asp-items="ViewBag.approverID"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

</body>
</html>

@{
    ViewData["Title"] = "Create Review";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create Review</title>

    <style>
        /* Blurred full-page background */
        .bg-blur {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('/images/inside.jpg') center/cover no-repeat;
            filter: blur(8px) brightness(0.6);
            z-index: -1;
        }

        /* Centered card */
        .review-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(4px);
            border-radius: 20px;
            padding: 2rem;
            max-width: 500px;
            margin: 5rem auto;
            box-shadow: 0 8px 25px rgba(0,0,0,0.2);
            animation: fadeIn 0.7s ease;
        }

        /* Fade animation */
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Hover effect for inputs */
        .form-control:hover {
            border-color: #6c63ff;
            transition: 0.2s ease;
        }

        .btn-primary {
            width: 100%;
            padding: 0.75rem;
            font-weight: bold;
            border-radius: 12px;
        }

        h2, h4 {
            text-align: center;
            color: #fff;
            text-shadow: 0 2px 6px rgba(0,0,0,0.4);
        }
    </style>
</head>

<body>

    <div class="bg-blur"></div>

    <h2>Book Review</h2>
    <h4>@ViewBag.BookName</h4>

    <div class="review-card">

        <form asp-action="Create">
            <input type="hidden" name="reviewerID" value="@ViewBag.userID" />
            <input type="hidden" name="book" value="@ViewBag.bookID" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <!-- Rating Dropdown -->
            <div class="form-group mb-3">
                <label asp-for="Rating" class="form-label"></label>
                <select asp-for="Rating" class="form-control">
                    <option value="">-- Select Rating --</option>
                    <option value="1">1 ⭐</option>
                    <option value="2">2 ⭐⭐</option>
                    <option value="3">3 ⭐⭐⭐</option>
                    <option value="4">4 ⭐⭐⭐⭐</option>
                    <option value="5">5 ⭐⭐⭐⭐⭐</option>
                </select>
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>

            <!-- Review Text -->
            <div class="form-group mb-3">
                <label asp-for="ReviewText" class="form-label"></label>
                <textarea asp-for="ReviewText" class="form-control" rows="3" placeholder="Write your review..."></textarea>
                <span asp-validation-for="ReviewText" class="text-danger"></span>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-primary">
                Submit Review
            </button>
        </form>

        <div class="mt-3 text-center">
            <a asp-action="Index" class="text-dark">← Back to List</a>
        </div>

    </div>

</body>

</html>
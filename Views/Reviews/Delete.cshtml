@{
    ViewData["Title"] = "Delete Review";
}

<div class="container mt-5 d-flex justify-content-center">
    <div class="card p-4 shadow" style="max-width: 500px; width: 100%;">
        <h3 class="text-center mb-4">Are you sure you want to delete this review?</h3>

        <form asp-action="Delete" class="text-center">
            <input type="hidden" asp-for="ReviewID" />

            <button type="submit" class="btn btn-danger btn-lg px-4 me-3">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary btn-lg px-4">
                Cancel
            </a>
        </form>
    </div>
</div>
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>ApproveReviews</title>
</head>

<body>
    <table class="table table-striped table-bordered">
        <thead class="table-light">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Rating)</th>
                <th>@Html.DisplayNameFor(model => model.ReviewText)</th>
                <th>APPROVED / REJECTED</th>
                <th>Customer</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                //--------------------------------------------------
                // EMPLOYEE FILTER:
                // Employees only see pending (DisputeStatus == null)
                // Admins see everything (no filter)
                //--------------------------------------------------
                if (User.IsInRole("Employee") && item.DisputeStatus != null)
                {
                    continue; // skip approved/rejected for employees
                }

                <tr>
                    <td>@item.Rating</td>

                    <td>@item.ReviewText</td>

                    <td>
                        @(item.DisputeStatus == true
                        ? "Approved"
                        : item.DisputeStatus == false
                            ? "Rejected"
                            : "Pending")
                    </td>

                    <td>@item.reviewer.UserName</td>

                    <td>
                        <!-- BOTH Admins & Employees can approve/reject -->
                        <form asp-action="UpdateReview" method="post" style="display:inline;">
                            <input type="hidden" name="ReviewID" value="@item.ReviewID" />
                            <input type="hidden" name="DisputeStatus" value="true" />
                            <button type="submit" class="btn btn-success btn-sm">Approve</button>
                        </form>

                        <form asp-action="UpdateReview" method="post" style="display:inline;">
                            <input type="hidden" name="ReviewID" value="@item.ReviewID" />
                            <input type="hidden" name="DisputeStatus" value="false" />
                            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
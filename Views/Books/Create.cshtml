<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="mb-3 text-center">Create New Book</h3>
                    <hr />

                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>


                        <!-- Title -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="BookDescription" class="form-label"></label>
                            <input asp-for="BookDescription" class="form-control" />
                            <span asp-validation-for="BookDescription" class="text-danger"></span>
                        </div>

                        <!-- Price -->
                        <div class="mb-3">
                            <label asp-for="BookPrice" class="form-label"></label>
                            <input asp-for="BookPrice" class="form-control" />
                            <span asp-validation-for="BookPrice" class="text-danger"></span>
                        </div>

                        <!-- Cost -->
                        <div class="mb-3">
                            <label asp-for="BookCost" class="form-label"></label>
                            <input asp-for="BookCost" class="form-control" />
                            <span asp-validation-for="BookCost" class="text-danger"></span>
                        </div>

                        <!-- Publish Date -->
                        <div class="mb-3">
                            <label asp-for="PublishDate" class="form-label"></label>
                            <input asp-for="PublishDate" class="form-control" />
                            <span asp-validation-for="PublishDate" class="text-danger"></span>
                        </div>

                        <!-- Inventory -->
                        <div class="mb-3">
                            <label asp-for="InventoryQuantity" class="form-label"></label>
                            <input asp-for="InventoryQuantity" class="form-control" />
                            <span asp-validation-for="InventoryQuantity" class="text-danger"></span>
                        </div>

                        <!-- Reorder Point -->
                        <div class="mb-3">
                            <label asp-for="ReorderPoint" class="form-label"></label>
                            <input asp-for="ReorderPoint" class="form-control" />
                            <span asp-validation-for="ReorderPoint" class="text-danger"></span>
                        </div>

                        <!-- Authors -->
                        <div class="mb-3">
                            <label asp-for="Authors" class="form-label"></label>
                            <input asp-for="Authors" class="form-control" />
                            <span asp-validation-for="Authors" class="text-danger"></span>
                        </div>


                        <!-- GENRE SELECTION -->
                        <div class="mb-3">
                            <label class="form-label">Select Existing Genre</label>

                            <select name="SelectedGenreID"
                                    class="form-select"
                                    asp-items="ViewBag.AllGenres">
                                <option value="">-- Choose Genre --</option>
                            </select>
                        </div>

                        <div class="text-center mb-2">
                            <strong>OR</strong>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Create New Genre</label>
                            <input type="text" name="NewGenreName"
                                   class="form-control"
                                   placeholder="Enter new genre" />
                        </div>

                        <!-- Status -->
                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="BookStatus" />
                            <label class="form-check-label" asp-for="BookStatus"></label>
                        </div>

                        <!-- Create Button -->
                        <div class="d-grid">
                            <input type="submit" value="Create Book" class="btn btn-primary" />
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <a asp-action="Index" class="text-decoration-none">&larr; Back to List</a>
            </div>

        </div>
    </div>
</div>
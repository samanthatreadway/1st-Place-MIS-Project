<div class="table-responsive">
    <table class="table table-striped table-hover align-middle shadow-sm">
        <thead class="table-light">
            <tr>
                <th>@Html.DisplayNameFor(model => model.BookNumber)</th>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.BookDescription)</th>
                <th>@Html.DisplayNameFor(model => model.BookPrice)</th>

                @if (User.IsInRole("Admin"))
                {
                    <th>@Html.DisplayNameFor(model => model.BookCost)</th>
                }

                <th>@Html.DisplayNameFor(model => model.PublishDate)</th>
                <th>@Html.DisplayNameFor(model => model.InventoryQuantity)</th>

                @if (User.IsInRole("Admin"))
                {
                    <th>@Html.DisplayNameFor(model => model.ReorderPoint)</th>
                }

                <th>@Html.DisplayNameFor(model => model.Authors)</th>

                @if (User.IsInRole("Admin"))
                {
                    <th>@Html.DisplayNameFor(model => model.BookStatus)</th>
                }

                <th>@Html.DisplayNameFor(model => model.genre.GenreName)</th>
                <th>@Html.DisplayNameFor(model => model.AverageRating)</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr class="clickable-row" data-href="@Url.Action("Details", "Books", new { id = item.BookID })" style="cursor:pointer;">
                    <td>@Html.DisplayFor(modelItem => item.BookNumber)</td>
                    <td>@Html.DisplayFor(modelItem => item.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.BookDescription)</td>
                    <td>@Html.DisplayFor(modelItem => item.BookPrice)</td>

                    @if (User.IsInRole("Admin"))
                    {
                        <td>@Html.DisplayFor(modelItem => item.BookCost)</td>
                    }

                    <td>@Html.DisplayFor(modelItem => item.PublishDate)</td>
                    <td>@Html.DisplayFor(modelItem => item.InventoryQuantity)</td>

                    @if (User.IsInRole("Admin"))
                    {
                        <td>@Html.DisplayFor(modelItem => item.ReorderPoint)</td>
                    }

                    <td>@Html.DisplayFor(modelItem => item.Authors)</td>

                    @if (User.IsInRole("Admin"))
                    {
                        <td>@Html.DisplayFor(modelItem => item.BookStatus)</td>
                    }

                    <td>@Html.DisplayFor(modelItem => item.genre.GenreName)</td>
                    @*<td>@Html.DisplayFor(modelItem => item.AverageRating)</td>*@
                    <td>@item.AverageRating.ToString("0.0")</td>

                    <td class="text-center">
                        <div class="btn-group" role="group">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.BookID" class="btn btn-sm btn-warning">Edit</a>
                            }

                            <a asp-action="BooksReviews" asp-controller="Reviews" asp-route-id="@item.BookID" class="btn btn-sm btn-info">Current Reviews</a>

                            <a asp-action="Details" asp-route-id="@item.BookID" class="btn btn-sm btn-secondary">Details</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".clickable-row").forEach(row => {

            row.addEventListener("click", function (e) {

                // If the click was on a button or link, do not trigger row navigation
                if (e.target.closest("a") || e.target.closest("button")) {
                    return;
                }

                window.location = this.dataset.href;
            });
        });
    });</script>




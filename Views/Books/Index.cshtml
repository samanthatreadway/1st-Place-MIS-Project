<div class="card mb-4 shadow-sm">
    <div class="card-body">

        <form asp-action="Index" asp-controller="Books"
              asp-route-SortOrder="most_popular"
              asp-route-SearchString="@ViewBag.CurrentSearchString"
              method="get" class="row g-3">

            <!-- =======================
                 TOP ROW: Search + Sort
            ======================== -->
            <div class="col-12 d-flex align-items-center">

                <!-- Search bar full width -->
                <input name="SearchString"
                       value="@ViewData["CurrentSearch"]"
                       class="form-control me-3"
                       style="flex: 1;"
                       placeholder="Search by title or description..." />

                <!-- Sort dropdown aligned right -->
                <select name="SortOrder" class="form-select" style="max-width: 220px;">
                    <option value="">Sort By...</option>
                    <option value="title_asc">Title (A–Z)</option>
                    <option value="title_desc">Title (Z–A)</option>
                    <option value="author_asc">Author (A–Z)</option>
                    <option value="author_desc">Author (Z–A)</option>
                    <option value="newest">Newest</option>
                    <option value="oldest">Oldest</option>
                    <option value="highest_rated">Highest Rated</option>
                    <option value="most_popular">Most Popular</option>
                </select>

            </div>

            <!-- =======================
                 SECOND ROW: Buttons
            ======================== -->
            <div class="col-12 d-flex gap-2 mt-2">

                <button type="submit" class="btn btn-success">
                    Search
                </button>

                <a asp-action="DetailedSearch" class="btn btn-outline-success">
                    Detailed Search
                </a>

                <a asp-action="Index" class="btn btn-danger">
                    Show All
                </a>

                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="InStockCheck" name="stock" value="true">
                    <label class="form-check-label" for="InStockCheck">In Stock</label>
                </div>

            </div>

        </form>

    </div>
</div>


<p class="text-muted">
    Displaying <strong>@ViewBag.BookCountSelected</strong> out of <strong>@ViewBag.BookCountTotal</strong> Books
</p>




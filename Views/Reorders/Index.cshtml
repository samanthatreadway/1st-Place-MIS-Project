@model List<fa25group23final.Models.ReorderDetails>

@{
    ViewData["Title"] = "Pending Book Orders";
}


<h2>Book Procurement - Current Pending Orders</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["InfoMessage"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @TempData["InfoMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3">
    <a asp-action="ManualOrder" class="btn btn-primary">Manual Reorder</a>
    <a asp-action="AutoReorder" class="btn btn-success">Auto Reorder</a>
    <a asp-action="ViewDraft" class="btn btn-secondary">View Reorder Cart</a>
    <a asp-action="History" class="btn btn-outline-secondary">View Reorder History</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No pending orders to receive.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Order Date</th>
                <th>Book Title</th>
                <th>Qty Ordered</th>
                <th>Qty Received</th>
                <th>Remaining</th>
                <th>Cost/Unit</th>
                <th>Receive</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                int remaining = item.QuantityOrdered - item.QuantityReceived;
                <tr>
                    <td>@item.Reorder.OrderDate?.ToString("MM/dd/yyyy")</td>
                    <td>@item.Book.Title</td>
                    <td>@item.QuantityOrdered</td>
                    <td>@item.QuantityReceived</td>
                    <td>@remaining</td>
                    <td>@item.Cost.ToString("C")</td>
                    <td>
                        <form asp-action="Receive" method="post" class="d-inline-flex align-items-center gap-2">
                            <input type="hidden" name="reorderDetailsId" value="@item.ReorderDetailsID" />
                            <input type="number" name="quantityArrived" value="@remaining" min="0" max="@remaining" class="form-control form-control-sm" style="width: 80px;" />
                            <button type="submit" class="btn btn-success btn-sm">Receive</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <strong>Total Pending Items:</strong> @Model.Sum(m => m.QuantityOrdered - m.QuantityReceived)
    </div>
}

@model List<fa25group23final.Models.ReorderDetails>

@{
    ViewData["Title"] = "Auto Reorder";
}

<h2>Automatic Reorder - Books Below Reorder Point</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">Back to Pending Orders</a>
    <a asp-action="ManualOrder" class="btn btn-outline-primary">Manual Reorder</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success">
        All books are at or above their reorder points. No action needed.
    </div>
}
else
{
    <form asp-action="PlaceAutoOrder" method="post" id="autoReorderForm">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Book Title</th>
                    <th>Current Inventory</th>
                    <th>Reorder Point</th>
                    <th>Last Cost</th>
                    <th>Order Qty</th>
                    <th>Cost/Unit</th>
                    <th>Remove</th>
                </tr>
            </thead>
            <tbody id="reorderTableBody">
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr data-row-id="@i">
                        <td>
                            @Model[i].Book.Title
                            <input type="hidden" name="bookIds" value="@Model[i].Book.BookID" class="book-id-input" />
                        </td>
                        <td>@Model[i].Book.InventoryQuantity</td>
                        <td>@Model[i].Book.ReorderPoint</td>
                        <td>@Model[i].Book.BookCost.ToString("C")</td>
                        <td>
                            <input type="number" name="quantities" value="@Model[i].QuantityOrdered" min="0" class="form-control form-control-sm qty-input" style="width: 80px;" />
                        </td>
                        <td>
                            <input type="number" name="costs" value="@Model[i].Cost" min="0.01" step="0.01" class="form-control form-control-sm cost-input" style="width: 100px;" />
                        </td>
                        <td>
                            <button type="button" class="btn btn-danger btn-sm remove-btn">Remove</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3 d-flex justify-content-between align-items-center">
            <div>
                <span class="text-muted" id="itemCount">@Model.Count book(s) to order</span>
            </div>
            <div>
                <button type="submit" class="btn btn-primary btn-lg" id="placeOrderBtn">Place All Orders</button>
            </div>
        </div>
    </form>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var tableBody = document.getElementById('reorderTableBody');
            var itemCountSpan = document.getElementById('itemCount');
            var placeOrderBtn = document.getElementById('placeOrderBtn');

            function updateItemCount() {
                var visibleRows = tableBody.querySelectorAll('tr:not(.removed)');
                var count = visibleRows.length;
                itemCountSpan.textContent = count + ' book(s) to order';
                
                // Disable button if no items
                if (count === 0) {
                    placeOrderBtn.disabled = true;
                    placeOrderBtn.textContent = 'No Items to Order';
                } else {
                    placeOrderBtn.disabled = false;
                    placeOrderBtn.textContent = 'Place All Orders';
                }
            }

            // Remove row functionality - completely removes from DOM
            tableBody.addEventListener('click', function(e) {
                if (e.target.classList.contains('remove-btn')) {
                    var row = e.target.closest('tr');
                    row.remove();
                    updateItemCount();
                }
            });
        });
    </script>
}

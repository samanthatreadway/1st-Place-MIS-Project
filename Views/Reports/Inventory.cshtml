@model fa25group23final.Models.InventoryReportViewModel
@{
    ViewData["Title"] = "Current Inventory Report";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="display-5">
                <i class="bi bi-box-seam"></i> Current Inventory Report
            </h1>
            <p class="text-muted">Books in stock with weighted average costs</p>
            <hr />
        </div>
    </div>

    <!-- Filters -->
    <partial name="_FilterPartial" model="Model.Filters" />

    <!-- Summary Stats -->
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2 text-muted">Books in Stock</h6>
                    <h3 class="card-title mb-0">@Model.TotalRecords</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2">Total Units</h6>
                    <h3 class="card-title mb-0">@Model.Results.Sum(r => r.InventoryQuantity)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2">Total Inventory Value</h6>
                    <h2 class="card-title mb-0">@Model.TotalInventoryValue.ToString("C")</h2>
                    <small>(All inventory, not just current page)</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Table -->
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Report Results</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Results.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Book Title</th>
                                <th>Authors</th>
                                <th>Genre</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-end">Avg Cost</th>
                                <th class="text-end">Total Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Results)
                            {
                                <tr>
                                    <td>
                                        <strong>@row.BookTitle</strong>
                                    </td>
                                    <td>
                                        <small class="text-muted">@row.Authors</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@row.GenreName</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(row.InventoryQuantity > 50 ? "bg-success" : row.InventoryQuantity > 20 ? "bg-warning" : "bg-danger")">
                                            @row.InventoryQuantity
                                        </span>
                                    </td>
                                    <td class="text-end">@row.WeightedAvgCost.ToString("C")</td>
                                    <td class="text-end">
                                        <strong>@row.TotalValue.ToString("C")</strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="3" class="text-end">Page Totals:</th>
                                <th class="text-center">@Model.Results.Sum(r => r.InventoryQuantity)</th>
                                <th></th>
                                <th class="text-end">@Model.Results.Sum(r => r.TotalValue).ToString("C")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info m-3">
                    <i class="bi bi-info-circle"></i> No inventory found matching the selected criteria.
                </div>
            }
        </div>
    </div>

    <!-- Total Inventory Value Summary -->
    <div class="card mt-3 border-danger">
        <div class="card-body bg-light">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h4 class="mb-0">
                        <i class="bi bi-cash-stack"></i> Total Inventory Value (All Books in Stock)
                    </h4>
                    <p class="text-muted mb-0">
                        <small>Sum of (Quantity × Weighted Avg Cost) for all books with inventory &gt; 0</small>
                    </p>
                </div>
                <div class="col-md-4 text-end">
                    <h2 class="text-danger mb-0">@Model.TotalInventoryValue.ToString("C")</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Report pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("Inventory", new { 
                           PageNumber = Model.CurrentPage - 1,
                           Model.Filters.SortBy,
                           Model.Filters.GenreId
                       })">
                        Previous
                    </a>
                </li>

                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" 
                           href="@Url.Action("Inventory", new { 
                               PageNumber = i,
                               Model.Filters.SortBy,
                               Model.Filters.GenreId
                           })">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("Inventory", new { 
                           PageNumber = Model.CurrentPage + 1,
                           Model.Filters.SortBy,
                           Model.Filters.GenreId
                       })">
                        Next
                    </a>
                </li>
            </ul>
        </nav>
    }

    <!-- Info Alert -->
    <div class="alert alert-info mt-4">
        <h5 class="alert-heading">
            <i class="bi bi-info-circle"></i> Inventory Legend
        </h5>
        <ul class="mb-0">
            <li>
                <span class="badge bg-success">Green badge</span> - High stock (&gt; 50 units)
            </li>
            <li>
                <span class="badge bg-warning">Yellow badge</span> - Medium stock (21-50 units)
            </li>
            <li>
                <span class="badge bg-danger">Red badge</span> - Low stock (≤ 20 units)
            </li>
            <li><strong>Weighted Avg Cost:</strong> Based on all received reorders</li>
            <li><strong>Total Value:</strong> Quantity × Weighted Avg Cost</li>
        </ul>
    </div>

    <!-- Back Button -->
    <div class="row mt-4">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Reports Dashboard
            </a>
        </div>
    </div>
</div>

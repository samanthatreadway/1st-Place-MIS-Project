@model fa25group23final.Models.CustomersReportViewModel
@{
    ViewData["Title"] = "All Customers Report";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="display-5">
                <i class="bi bi-people"></i> All Customers Report
            </h1>
            <p class="text-muted">Customer lifetime value analysis</p>
            <hr />
        </div>
    </div>

    <!-- Filters -->
    <partial name="_FilterPartial" model="Model.Filters" />

    <!-- Summary Stats -->
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2 text-muted">Total Customers</h6>
                    <h3 class="card-title mb-0">@Model.TotalRecords</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2">Total Revenue</h6>
                    <h3 class="card-title mb-0">@Model.Results.Sum(r => r.TotalRevenue).ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2">Total Profit</h6>
                    <h3 class="card-title mb-0">@Model.Results.Sum(r => r.TotalProfit).ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2 text-muted">Avg Revenue/Customer</h6>
                    <h3 class="card-title mb-0">
                        @if (Model.Results.Any())
                        {
                            @((Model.Results.Sum(r => r.TotalRevenue) / Model.Results.Count).ToString("C"))
                        }
                        else
                        {
                            @:$0.00
                        }
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Table -->
    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Report Results</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Results.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Customer Name</th>
                                <th>Email</th>
                                <th class="text-center">Orders</th>
                                <th class="text-center">Items</th>
                                <th class="text-end">Revenue</th>
                                <th class="text-end">Cost</th>
                                <th class="text-end">Profit Margin</th>
                                <th class="text-end">Margin %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Results)
                            {
                                <tr>
                                    <td>
                                        <strong>@row.CustomerName</strong>
                                    </td>
                                    <td>
                                        <small class="text-muted">@row.Email</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-primary">@row.TotalOrders</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">@row.TotalItemsPurchased</span>
                                    </td>
                                    <td class="text-end">
                                        <strong>@row.TotalRevenue.ToString("C")</strong>
                                    </td>
                                    <td class="text-end text-muted">@row.TotalCost.ToString("C")</td>
                                    <td class="text-end">
                                        <strong class="@(row.TotalProfit >= 0 ? "text-success" : "text-danger")">
                                            @row.TotalProfit.ToString("C")
                                        </strong>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge @(row.ProfitMarginPercent >= 0 ? "bg-success" : "bg-danger")">
                                            @row.ProfitMarginPercent.ToString("F2")%
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="4" class="text-end">Totals (Current Page):</th>
                                <th class="text-end">@Model.Results.Sum(r => r.TotalRevenue).ToString("C")</th>
                                <th class="text-end">@Model.Results.Sum(r => r.TotalCost).ToString("C")</th>
                                <th class="text-end">@Model.Results.Sum(r => r.TotalProfit).ToString("C")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info m-3">
                    <i class="bi bi-info-circle"></i> No customers found matching the selected criteria.
                </div>
            }
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Report pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("Customers", new { 
                           PageNumber = Model.CurrentPage - 1,
                           Model.Filters.SortBy
                       })">
                        Previous
                    </a>
                </li>

                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" 
                           href="@Url.Action("Customers", new { 
                               PageNumber = i,
                               Model.Filters.SortBy
                           })">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("Customers", new { 
                           PageNumber = Model.CurrentPage + 1,
                           Model.Filters.SortBy
                       })">
                        Next
                    </a>
                </li>
            </ul>
        </nav>
    }

    <!-- Back Button -->
    <div class="row mt-4">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Reports Dashboard
            </a>
        </div>
    </div>
</div>

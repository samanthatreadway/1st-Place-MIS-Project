@model fa25group23final.Models.EmployeeReviewsReportViewModel
@{
    ViewData["Title"] = "Employee Reviews Report";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="display-5">
                <i class="bi bi-star"></i> Employee Reviews Report
            </h1>
            <p class="text-muted">Track employee review approval/rejection activity</p>
            <hr />
        </div>
    </div>

    <!-- Filters -->
    <partial name="_FilterPartial" model="Model.Filters" />

    <!-- Summary Stats -->
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2 text-muted">Total Employees</h6>
                    <h3 class="card-title mb-0">@Model.TotalRecords</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2">Total Approved</h6>
                    <h3 class="card-title mb-0">@Model.Results.Sum(r => r.ApprovedCount)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2">Total Rejected</h6>
                    <h3 class="card-title mb-0">@Model.Results.Sum(r => r.RejectedCount)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h6 class="card-subtitle mb-2">Total Reviews</h6>
                    <h3 class="card-title mb-0">@Model.Results.Sum(r => r.TotalReviews)</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Table -->
    <div class="card">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">Report Results</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Results.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Employee Name</th>
                                <th>Email</th>
                                <th class="text-center">
                                    <i class="bi bi-check-circle text-success"></i> Approved
                                </th>
                                <th class="text-center">
                                    <i class="bi bi-x-circle text-danger"></i> Rejected
                                </th>
                                <th class="text-center">Total</th>
                                <th class="text-center">Approval Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Results)
                            {
                                <tr>
                                    <td>
                                        <strong>@row.EmployeeName</strong>
                                    </td>
                                    <td>
                                        <small class="text-muted">@row.Email</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success fs-6">@row.ApprovedCount</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-danger fs-6">@row.RejectedCount</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary fs-6">@row.TotalReviews</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="progress" style="height: 25px;">
                                            <div class="progress-bar bg-success" 
                                                 role="progressbar" 
                                                 style="width: @row.ApprovalRate%"
                                                 aria-valuenow="@row.ApprovalRate" 
                                                 aria-valuemin="0" 
                                                 aria-valuemax="100">
                                                @row.ApprovalRate.ToString("F1")%
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="2" class="text-end">Totals (Current Page):</th>
                                <th class="text-center">@Model.Results.Sum(r => r.ApprovedCount)</th>
                                <th class="text-center">@Model.Results.Sum(r => r.RejectedCount)</th>
                                <th class="text-center">@Model.Results.Sum(r => r.TotalReviews)</th>
                                <th class="text-center">
                                    @if (Model.Results.Any() && Model.Results.Sum(r => r.TotalReviews) > 0)
                                    {
                                        var avgRate = (Model.Results.Sum(r => r.ApprovedCount) / (decimal)Model.Results.Sum(r => r.TotalReviews) * 100);
                                        @($"{avgRate:F2}%")
                                        @* @avgRate.ToString("F2")% *@
                                    }
                                    else
                                    {
                                        @:0.00%
                                    }
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info m-3">
                    <i class="bi bi-info-circle"></i> No employee review data found matching the selected criteria.
                </div>
            }
        </div>
    </div>

    <!-- Performance Analysis -->
    @if (Model.Results.Any())
    {
        var topApprover = Model.Results.OrderByDescending(r => r.ApprovedCount).FirstOrDefault();
        var topRejecter = Model.Results.OrderByDescending(r => r.RejectedCount).FirstOrDefault();
        var mostActive = Model.Results.OrderByDescending(r => r.TotalReviews).FirstOrDefault();

        <div class="row mt-4 g-3">
            <div class="col-md-4">
                <div class="card border-success">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0">
                            <i class="bi bi-trophy"></i> Most Approvals
                        </h6>
                    </div>
                    <div class="card-body">
                        <h5>@topApprover.EmployeeName</h5>
                        <p class="mb-0 text-success">
                            <strong>@topApprover.ApprovedCount approved reviews</strong>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <h6 class="mb-0">
                            <i class="bi bi-x-octagon"></i> Most Rejections
                        </h6>
                    </div>
                    <div class="card-body">
                        <h5>@topRejecter.EmployeeName</h5>
                        <p class="mb-0 text-danger">
                            <strong>@topRejecter.RejectedCount rejected reviews</strong>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-info">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0">
                            <i class="bi bi-award"></i> Most Active
                        </h6>
                    </div>
                    <div class="card-body">
                        <h5>@mostActive.EmployeeName</h5>
                        <p class="mb-0 text-info">
                            <strong>@mostActive.TotalReviews total reviews</strong>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Report pagination" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("EmployeeReviews", new { 
                           PageNumber = Model.CurrentPage - 1,
                           Model.Filters.SortBy,
                           Model.Filters.EmployeeId,
                           Model.Filters.ReviewStatus
                       })">
                        Previous
                    </a>
                </li>

                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" 
                           href="@Url.Action("EmployeeReviews", new { 
                               PageNumber = i,
                               Model.Filters.SortBy,
                               Model.Filters.EmployeeId,
                               Model.Filters.ReviewStatus
                           })">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("EmployeeReviews", new { 
                           PageNumber = Model.CurrentPage + 1,
                           Model.Filters.SortBy,
                           Model.Filters.EmployeeId,
                           Model.Filters.ReviewStatus
                       })">
                        Next
                    </a>
                </li>
            </ul>
        </nav>
    }

    <!-- Info Alert -->
    <div class="alert alert-info mt-4">
        <h5 class="alert-heading">
            <i class="bi bi-info-circle"></i> Report Notes
        </h5>
        <ul class="mb-0">
            <li><strong>Approved:</strong> Reviews where employee set status to approved (DisputeStatus = true)</li>
            <li><strong>Rejected:</strong> Reviews where employee set status to rejected (DisputeStatus = false)</li>
            <li><strong>Approval Rate:</strong> (Approved / Total) × 100</li>
            <li>Only includes reviews that have been processed (not pending)</li>
            <li>Only shows employees who have approved or rejected at least one review</li>
        </ul>
    </div>

    <!-- Back Button -->
    <div class="row mt-4">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Reports Dashboard
            </a>
        </div>
    </div>
</div>
